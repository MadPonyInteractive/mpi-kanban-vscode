// A launch configuration that compiles the extension and then opens it inside a new window
// Use IntelliSense to learn about possible attributes.
// Hover to view descriptions of existing attributes.
// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js"
			],
			"preLaunchTask": "${defaultBuildTask}"
		},
		{
			"name": "Run Extension (sample board)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"${workspaceFolder}/test/fixtures/sample-board",
				"${workspaceFolder}/test/fixtures/sample-board/.agents/mpi-kanban/kanban.md",
				"--extensionDevelopmentPath=${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js"
			],
			"preLaunchTask": "${defaultBuildTask}"
		},
		{
			"name": "Extension Tests",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}",
				"--extensionTestsPath=${workspaceFolder}/out/test/extension.test.js"
			],
			"outFiles": [
				"${workspaceFolder}/out/test/**/*.js",
				"${workspaceFolder}/dist/**/*.js"
			],
			"preLaunchTask": "npm: pretest"
		}
	]
}
