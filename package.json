{
  "name": "mpi-kanban",
  "displayName": "Mpi-Kanban",
  "description": "VS Code Kanban board for the MPI agent workflow.",
  "publisher": "MadPonyInteractive",
  "version": "0.1.8",
  "author": {
    "name": "Madpony Interactive",
    "url": "https://github.com/MadPonyInteractive"
  },
  "license": "MIT",
  "pricing": "Free",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "imgs/logo.png",
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.agents/mpi-kanban/board.json",
    "workspaceContains:.agents/mpi-kanban/kanban.md",
    "workspaceContains:.claude/mpi-kanban/kanban.md"
  ],
  "main": "./dist/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/MadPonyInteractive/mpi-kanban-vscode"
  },
  "bugs": {
    "url": "https://github.com/MadPonyInteractive/mpi-kanban-vscode/issues"
  },
  "contributes": {
    "commands": [
      {
        "command": "mpi-kanban.openKanban",
        "title": "Open Mpi-Kanban Board",
        "category": "Mpi-Kanban",
        "icon": {
          "light": "imgs/logo.png",
          "dark": "imgs/logo.png"
        }
      },
      {
        "command": "mpi-kanban.openTaskById",
        "title": "Open Task by ID",
        "category": "Mpi-Kanban"
      },
      {
        "command": "mpi-kanban.installSkills",
        "title": "Install or Update Agent Skills",
        "category": "Mpi-Kanban"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "mpi-kanban.openKanban",
          "when": "mpiKanbanActive",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.19.10",
    "eslint": "^8.56.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "mpi",
    "kanban",
    "agents",
    "workflow",
    "planning"
  ]
}
